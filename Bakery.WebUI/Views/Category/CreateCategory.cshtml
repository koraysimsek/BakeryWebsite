@model Bakery.WebUI.Dtos.Categories.CreateCategoryDto

@{
    ViewData["Title"] = "CreateCategory";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-[#4b5563] p-6">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-800">
                Kategori Ekle
            </h1>
            <p class="text-gray-500 mt-1">
                Kategori bilgilerini giriniz
            </p>
        </div>

        <form method="post" class="space-y-6">

            <!-- Category Name -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Kategori Adı
                </label>
                <input type="text" asp-for="categoryName" required
                       placeholder="e.g. Tatlılar"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              text-gray-900
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827]
                              outline-none transition" />
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Açıklama
                </label>
                <textarea asp-for="description" rows="4" required
                          placeholder="Kategori açıklaması..."
                          class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                                 text-gray-900
                                 focus:ring-2 focus:ring-[#111827]
                                 focus:border-[#111827]
                                 outline-none transition"></textarea>
            </div>

            <!-- Button -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-[#111827] hover:bg-black
                               text-white font-semibold py-3 rounded-lg
                               transition shadow-lg">

                    <svg class="w-5 h-5" fill="none" stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 4v16m8-8H4" />
                    </svg>

                    Ekle
                </button>
            </div>

        </form>
    </div>

</div>
