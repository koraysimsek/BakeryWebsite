@model List<Bakery.WebUI.Dtos.Products.ProductWithCategoryDto>

@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="content-wrapper">
	<div class="page-header">
		<h3 class="page-title">
			<span class="page-title-icon bg-gradient-primary text-white me-2">
				<i class="mdi mdi-home"></i>
			</span> İstatistikler
		</h3>
	</div>
	<div class="row">
		<!-- Şefler -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-primary card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Şefler <i class="mdi mdi-chef-hat mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-5">@ViewBag.ChefCount</h2>
				</div>
			</div>
		</div>

		<!-- Kategoriler -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-info card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Kategoriler <i class="mdi mdi-folder-multiple mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-5">@ViewBag.CategoryCount</h2>
				</div>
			</div>
		</div>

		<!-- Aboneler -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-warning card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Abone Sayısı <i class="mdi mdi-email-outline mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-5">@ViewBag.SubscribeCount</h2>
				</div>
			</div>
		</div>
	</div>

	<div class="row">
		<!-- Ürünler -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-danger card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Ürünler <i class="mdi mdi-cake-variant mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-3">@ViewBag.ProductCount</h2>
					<h6 class="card-text">
						Son Eklenen Ürün: @ViewBag.ProductLast
					</h6>
				</div>
			</div>
		</div>

		<!-- Hizmetler -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-success card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Hizmetler <i class="mdi mdi-tools mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-3">@ViewBag.ServiceCount</h2>
					<h6 class="card-text">
						Son Eklenen Hizmet: @ViewBag.ServiceLast
					</h6>
				</div>
			</div>
		</div>

		<!-- Referanslar -->
		<div class="col-md-4 stretch-card grid-margin">
			<div class="card bg-gradient-secondary card-img-holder text-white">
				<div class="card-body">
					<h4 class="font-weight-normal mb-3">
						Referanslar <i class="mdi mdi-star-circle mdi-24px float-end"></i>
					</h4>
					<h2 class="mb-3">@ViewBag.TestimonialCount</h2>
					<h6 class="card-text">
						Son Referans: @ViewBag.TestimonialLast
					</h6>
				</div>
			</div>
		</div>
	</div>
	<div class="row">
		<div class="col-12 grid-margin">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">Son Eklenen 5 Ürün</h4>
					<br />
					<div class="table-responsive">
						<table class="table">
							<thead>
								<tr>
									<th style="width: 90px;">#</th>
									<th>Ürün Adı</th>
									<th>Fiyat</th>
									<th>Kategori</th>
									<th>Açıklama</th>
									<th>Görsel</th>
								</tr>
							</thead>
							<tbody>

								@foreach (var item in Model)
								{
									<tr>
										<td>
											<span class="pill">@item.ProductId</span>
										</td>

										<td class="col-title">
											<div class="title-main">@item.Name</div>
										</td>

										<td>
											@item.Price ₺
										</td>

										<td>
											<span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full">
												@item.CategoryName
											</span>
										</td>

										<td class="col-desc">
											<div class="text-clamp">@item.Description</div>
										</td>

										<td>
											<img src="@item.ImageUrl"
												 alt="Product Image"
												 style="width:70px;height:70px;object-fit:cover;border-radius:12px;border:1px solid #e5e7eb;box-shadow:0 4px 10px rgba(0,0,0,0.08);" />
										</td>
									</tr>
								}
							</tbody>
						</table>
						<br />
						<a href="/Product/ListProduct" class="btn btn-success">
							Ürünleri Düzenle
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
