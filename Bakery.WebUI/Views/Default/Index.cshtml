
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("DefaultHead")

<body>
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>
    <!-- Spinner End -->
    <!-- Navbar Start -->
    @await Component.InvokeAsync("DefaultNavbar")
    <!-- Navbar End -->
    <!-- Carousel Start -->
    @await Component.InvokeAsync("DefaultSlider")
    <!-- Carousel End -->
    <!-- Facts Start -->
    @await Component.InvokeAsync("DefaultStatistic")
    <!-- Facts End -->
    <!-- About Start -->
    @await Component.InvokeAsync("DefaultAbout")
    <!-- About End -->
    <!-- Product Start -->
    <div class="container-xxl bg-light my-6 py-6 pt-0">
        <div class="container">
            @await Component.InvokeAsync("DefaultContact")
            
            @await Component.InvokeAsync("DefaultProduct")
        </div>
    </div>
    <!-- Product End -->
    <!-- Service Start -->
    @await Component.InvokeAsync("DefaultService")
    <!-- Service End -->
    <!-- Team Start -->
    @await Component.InvokeAsync("DefaultChef")
    <!-- Team End -->
    <!-- Testimonial Start -->
    <div class="container-xxl bg-light my-6 py-6 pb-0">
        <div class="container">
            @await Component.InvokeAsync("DefaultTestimonial")

            @await Component.InvokeAsync("DefaultSubscribe")
        </div>
    </div>
    <!-- Testimonial End -->
    <!-- Footer Start -->
    <div class="container-fluid bg-dark text-light footer my-6 mb-0 py-5 wow fadeIn" data-wow-delay="0.1s">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-light mb-4">Adres</h4>
                    <p class="mb-2"><i class="fa fa-map-marker-alt me-3"></i>Ataşehir, İstanbul</p>
                    <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>+90 123 456 78 90</p>
                    <p class="mb-2"><i class="fa fa-envelope me-3"></i>simsek@fırın.com</p>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-light mb-4">Hızlı Araçlar</h4>
                    <a class="btn btn-link" href="#about">Hakkımızda</a>
                    <a class="btn btn-link" href="#contact">Bize Ulaşın</a>
                    <a class="btn btn-link" href="#service">Hizmetlerimiz</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->
    <!-- Copyright Start -->
    <div class="container-fluid copyright text-light py-4 wow fadeIn" data-wow-delay="0.1s">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a href="#">Şimşek Fırın</a>, All Right Reserved.
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <!--/*** This template is free as long as you keep the footer author’s credit link/attribution link/backlink. If you'd like to use the template without the footer author’s credit link/attribution link/backlink, you can purchase the Credit Removal License from "https://htmlcodex.com/credit-removal". Thank you for your support. ***/-->
                    Designed By <a href="https://htmlcodex.com">HTML Codex</a>
                    <br>Distributed By: <a class="border-bottom" href="https://themewagon.com" target="_blank">ThemeWagon</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Copyright End -->
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square rounded-circle back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/baker-1.0.0/lib/wow/wow.min.js"></script>
    <script src="~/baker-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/baker-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/baker-1.0.0/lib/counterup/counterup.min.js"></script>
    <script src="~/baker-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/baker-1.0.0/js/main.js"></script>
</body>

</html>