@model Bakery.WebUI.Dtos.Products.CreateProductDto

@{
    ViewData["Title"] = "CreateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-[#4b5563] p-6">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-800">
                Ürün Ekle
            </h1>
            <p class="text-gray-500 mt-1">
                Ürün bilgilerini giriniz
            </p>
        </div>

        <form method="post" action="/Product/CreateProduct" class="space-y-6">

            <!-- Name -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Ürün Adı
                </label>
                <input type="text" name="name" required
                       placeholder="e.g. Çikolatalı Pasta"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              text-gray-900 focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Price -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Fiyat
                </label>
                <input type="number" step="0.01" name="price" required
                       placeholder="e.g. 120.50"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              text-gray-900 focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Image -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Görsel URL
                </label>
                <input type="text" name="imageUrl" required
                       placeholder="https://example.com/product.jpg"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              text-gray-900 focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Category -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Ürünün Kategorisi
                </label>

                <select name="categoryId"
                        required
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                               text-gray-900 bg-white
                               focus:ring-2 focus:ring-indigo-500
                               focus:border-indigo-500
                               outline-none transition">

                    <option value="" disabled selected>Kategori Seçin</option>

                    @foreach (var item in ViewBag.Categories)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>

            <!-- Button -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-[#111827] hover:bg-black text-white
                               font-semibold py-3 rounded-lg transition shadow-lg">
                    Ekle
                </button>
            </div>

        </form>
    </div>

</div>

