@model Bakery.WebUI.Dtos.Services.CreateServiceDto

@{
    ViewData["Title"] = "CreateService";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-[#4b5563] p-6">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-800">
                Hizmet Ekle
            </h1>
            <p class="text-gray-500 mt-1">
                Hizmet bilgilerini giriniz
            </p>
        </div>

        <form method="post" action="/Service/CreateService" class="space-y-6">

            <!-- Title -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Başlık
                </label>
                <input type="text" name="title" required
                       placeholder="e.g. Premium Hizmet"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Açıklama
                </label>
                <textarea name="description" rows="3" required
                          placeholder="Kısa açıklama..."
                          class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                                 focus:ring-2 focus:ring-[#111827]
                                 focus:border-[#111827] outline-none transition"></textarea>
            </div>

            <!-- Service Name -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Hizmet Adı
                </label>
                <input type="text" name="serviceName" required
                       placeholder="e.g. Catering"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Service Description -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Hizmet Açıklaması
                </label>
                <textarea name="serviceDescription" rows="3" required
                          placeholder="Detaylı hizmet açıklaması..."
                          class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                                 focus:ring-2 focus:ring-[#111827]
                                 focus:border-[#111827] outline-none transition"></textarea>
            </div>

            <!-- Icon URL -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    İkon URL
                </label>
                <input type="text" name="serviceIconUrl" required
                       placeholder="https://example.com/icon.svg"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Image URL -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Görsel URL
                </label>
                <input type="text" name="imageUrl" required
                       placeholder="https://example.com/image.jpg"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827] outline-none transition" />
            </div>

            <!-- Button -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full bg-[#111827] hover:bg-black
                               text-white font-semibold py-3 rounded-lg
                               transition shadow-lg">
                    Ekle
                </button>
            </div>

        </form>

    </div>

</div>


