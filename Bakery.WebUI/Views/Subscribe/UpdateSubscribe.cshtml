@model Bakery.WebUI.Dtos.Subscribes.UpdateSubscribeDto

@{
    ViewData["Title"] = "UpdateSubscribe";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-[#4b5563] p-6">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-800">
                Abonelik Güncelle
            </h1>
            <p class="text-gray-500 mt-1">
                Abone email bilgisini güncelleyin
            </p>
        </div>

        <form method="post" class="space-y-6">

            <!-- Hidden Id -->
            @Html.HiddenFor(x => x.SubscribeId)

            <!-- Email -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Email
                </label>
                <input type="email"
                       asp-for="Email"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              text-gray-900
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827]
                              outline-none transition" />
            </div>

            <!-- Button -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-[#111827] hover:bg-black
                               text-white font-semibold py-3 rounded-lg
                               transition shadow-lg">

                    <svg class="w-5 h-5" fill="none" stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M5 13l4 4L19 7" />
                    </svg>

                    Güncelle
                </button>
            </div>

        </form>
    </div>

</div>

