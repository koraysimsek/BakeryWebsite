@model Bakery.WebUI.Dtos.Testimonials.CreateTestimonialDto

@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-[#4b5563] p-6">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-800">
                Referans Ekle
            </h1>
            <p class="text-gray-500 mt-1">
                Referans bilgilerini giriniz
            </p>
        </div>

        <form method="post" action="/Testimonial/CreateTestimonial" class="space-y-6">

            <!-- Name -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Ad Soyad
                </label>
                <input type="text" name="nameSurname" required
                       placeholder="e.g. Ahmet Yılmaz"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827]
                              outline-none transition" />
            </div>

            <!-- Title -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Ünvan
                </label>
                <input type="text" name="title" required
                       placeholder="e.g. Müşteri"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827]
                              outline-none transition" />
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Açıklama
                </label>
                <textarea name="description" rows="3" required
                          placeholder="Referans yorumu..."
                          class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                                 focus:ring-2 focus:ring-[#111827]
                                 focus:border-[#111827]
                                 outline-none transition"></textarea>
            </div>

            <!-- Image -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Görsel URL
                </label>
                <input type="text" name="imageUrl" required
                       placeholder="https://example.com/photo.jpg"
                       class="w-full px-4 py-2.5 rounded-lg border border-gray-300
                              focus:ring-2 focus:ring-[#111827]
                              focus:border-[#111827]
                              outline-none transition" />
            </div>

            <!-- Button -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full bg-[#111827] hover:bg-black
                               text-white font-semibold py-3 rounded-lg
                               transition shadow-lg">
                    Ekle
                </button>
            </div>

        </form>

    </div>

</div>


